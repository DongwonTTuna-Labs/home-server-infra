{
  "$id": "https://example.invalid/codex-review/review-memory.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "review-memory.v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "review-memory.v1",
      "type": "string"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": {
          "type": "string"
        },
        "pr_number": {
          "type": "integer"
        },
        "base_ref": {
          "type": "string"
        }
      },
      "required": [
        "repository",
        "pr_number",
        "base_ref"
      ]
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "entry_id": {
            "type": "string"
          },
          "created_at": {
            "format": "date-time",
            "type": "string"
          },
          "round": {
            "minimum": 0,
            "type": "integer"
          },
          "head_sha": {
            "type": "string"
          },
          "kind": {
            "enum": [
              "fix_applied",
              "decision",
              "learning",
              "rejected_approach",
              "open_risk",
              "resolved_finding"
            ],
            "type": "string"
          },
          "category": {
            "enum": [
              "learnings",
              "decisions",
              "issues",
              "problems"
            ],
            "type": "string"
          },
          "body": {
            "type": "object",
            "additionalProperties": true
          },
          "source_stage": {
            "type": "string"
          },
          "trusted": {
            "type": "boolean"
          },
          "finding_fingerprint": {
            "type": "string"
          },
          "provenance": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "required": [
          "entry_id",
          "created_at",
          "round",
          "head_sha",
          "kind",
          "category",
          "body",
          "source_stage",
          "trusted"
        ]
      }
    }
  },
  "required": [
    "schema_version",
    "scope",
    "entries"
  ]
}
