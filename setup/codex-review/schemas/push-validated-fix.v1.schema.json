{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Stage07 no-token validated fix",
  "type": "object",
  "required": ["schema_version", "status", "validated", "pushed"],
  "properties": {
    "schema_version": {"const": "push-validated-fix.v1"},
    "status": {"type": "string"},
    "validated": {"type": "boolean"},
    "pushed": {"const": false},
    "commit_sha": {"type": ["string", "null"]},
    "head_sha": {"type": "string"},
    "patch_hash": {"type": "string"},
    "applied_diff_hash": {"type": "string"},
    "apply_report": {"type": "object"},
    "policy_report": {"type": "object"},
    "test_report": {"type": "object"}
  },
  "additionalProperties": true
}
