{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Stage06 semantic patch safety review",
  "type": "object",
  "required": [
    "schema_version",
    "status",
    "approved",
    "patch_hash",
    "summary",
    "blocking_reason",
    "reviewed_criteria",
    "semantic_findings",
    "commit_plan"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "status": {"enum": ["approved", "rejected", "needs_issue", "not_required"]},
    "approved": {"type": "boolean"},
    "patch_hash": {"type": "string"},
    "summary": {"type": "string"},
    "blocking_reason": {"type": ["string", "null"]},
    "reviewed_criteria": {"type": "array", "items": {"type": "string"}},
    "semantic_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "title", "evidence", "recommendation"],
        "properties": {
          "severity": {"enum": ["critical", "high", "medium", "low", "info"]},
          "title": {"type": "string"},
          "evidence": {"type": "string"},
          "recommendation": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "commit_plan": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["subject", "body", "paths"],
        "properties": {
          "subject": {"type": "string"},
          "body": {"type": "string"},
          "paths": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
