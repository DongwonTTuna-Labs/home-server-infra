#!/usr/bin/env bash
set -euo pipefail

container="${FORGEJO_CONTAINER:-forgejo-forgejo-1}"
binary="${FORGEJO_BINARY:-/usr/local/bin/forgejo}"
config="${FORGEJO_CONFIG:-/var/lib/gitea/custom/conf/app.ini}"
work_path="${FORGEJO_WORK_PATH:-/var/lib/gitea}"

exec docker exec "$container" "$binary" \
  --config "$config" \
  --work-path "$work_path" \
  "$@"
