# Copy to stacks/paca/.env on the host only. Never commit the real file.
# Generate secret placeholders with a local password manager or openssl/rand.
# ENCRYPTION_KEY must be 64 hex chars and cannot be rotated without a
# decrypt/re-encrypt migration for existing encrypted agent LLM keys.

ENVIRONMENT=production
PUBLIC_URL=https://paca.dongwontuna.net
COOKIE_SECURE=true
CORS_ORIGINS=https://paca.dongwontuna.net
SITE_ADDRESS=:80

POSTGRES_DB=paca
POSTGRES_USER=paca
POSTGRES_PASSWORD=__GENERATE_STRONG_POSTGRES_PASSWORD__

JWT_SECRET=__GENERATE_STRONG_JWT_SECRET__
ADMIN_USERNAME=admin
ADMIN_PASSWORD=__GENERATE_STRONG_ADMIN_PASSWORD__
ENCRYPTION_KEY=__GENERATE_64_HEX_AND_REENCRYPT_EXISTING_AGENT_KEYS__
AGENT_API_KEY=__GENERATE_STRONG_AGENT_API_KEY__
INTERNAL_API_KEY=__GENERATE_STRONG_INTERNAL_API_KEY__

STORAGE_PROVIDER=minio
STORAGE_ENDPOINT=minio:9000
STORAGE_PUBLIC_URL=https://paca.dongwontuna.net/storage
STORAGE_REGION=us-east-1
STORAGE_BUCKET=paca
STORAGE_ACCESS_KEY_ID=__GENERATE_STRONG_STORAGE_ACCESS_KEY_ID__
STORAGE_SECRET_ACCESS_KEY=__GENERATE_STRONG_STORAGE_SECRET_ACCESS_KEY__
STORAGE_USE_SSL=false

BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=7
BACKUP_CRON=0 2 * * *
TZ=UTC

# Optional image pins. Leave unset to use the compose defaults.
# PACA_API_IMAGE=pacaai/paca-api:<version>
# PACA_WEB_IMAGE=pacaai/paca-web:<version>
# PACA_REALTIME_IMAGE=pacaai/paca-realtime:<version>
# PACA_AI_AGENT_IMAGE=pacaai/paca-ai-agent:<version>
# AGENT_SERVER_IMAGE=ghcr.io/openhands/agent-server:<version>
