# Copy to stacks/opencode/.env (gitignored) and fill in real values.
# This file is consumed by compose interpolation when you run:
#   docker compose -f stacks/opencode/compose.yaml up -d

# HTTP basic auth for the opencode server (browser + `opencode attach`).
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=change-me-strong-password

# API key for the ai-relay (codex-lb) provider used by opencode.json.
# Create it in the codex-lb dashboard (Settings -> API Keys), no expiration.
CODEX_LB_LOCAL_API_KEY=sk-clb-change-me
