# Copy to .env and adjust before starting Forgejo.

FORGEJO_DOMAIN=git.dongwontuna.net
FORGEJO_SSH_DOMAIN=ssh.dongwontuna.net
FORGEJO_ROOT_URL=https://git.dongwontuna.net/
FORGEJO_APP_NAME="DongwonTTuna Forge"
FORGEJO_APP_SLOGAN="Code lives here."

FORGEJO_UID=1000
FORGEJO_GID=1000

POSTGRES_DB=forgejo
POSTGRES_USER=forgejo
POSTGRES_PASSWORD=change-me-use-openssl-rand-hex-32

# Forgejo migration/API scripts.
FORGEJO_API_URL=https://git.dongwontuna.net/api/v1
FORGEJO_OWNER=DongwonTTuna-Labs
FORGEJO_TOKEN=
GITHUB_OWNER=DongwonTTuna-Labs

# SSH clone root used after migration.
FORGEJO_SSH_BASE=git@ssh.dongwontuna.net:DongwonTTuna-Labs

# Optional: used by scripts/archive-github.sh after the cutover.
GITHUB_READONLY_DESCRIPTION_PREFIX="Migrated to Forgejo:"

# Optional: register runner offline. Must be 40 hex chars.
FORGEJO_RUNNER_SECRET=
FORGEJO_RUNNER_NAME=home-server-runner
FORGEJO_RUNNER_INSTANCE_URL=http://forgejo:3000
FORGEJO_RUNNER_LABELS=ubuntu-latest:docker://node:24-bookworm,rust:docker://rust:1-bookworm
