# Put an org-scoped fine-grained PAT in ./state/github_pat for first-time
# registration. DongwonTTuna-Labs currently requires PAT expiration <= 366 days.
# The PAT needs access to manage organization self-hosted runners. After all
# runners are registered, ./state/github_pat can be chmod 0600 or rotated away.

# Host-wide maximum number of self-hosted jobs allowed past the runner
# pre-job hook at the same time.
CODEX_RUNNER_MAX_PARALLEL=8

# Keep Codex CLI current. Runners check npm before container startup and before
# each job starts. Set CODEX_CLI_VERSION to a concrete version only for rollback.
CODEX_CLI_AUTO_UPDATE=1
CODEX_CLI_VERSION=latest

# The Home Server Runners group is configured for all repositories in the
# organization, including public repositories. Set this to selected only if the
# GitHub runner group policy is changed to selected repositories.
RUNNER_GROUP_SCOPE=all
